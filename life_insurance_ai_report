<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>壽險業 AI 變現地圖 — 台灣落地評估 2026</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#09180f;--bgc:#0d1f16;--bgc2:#122519;
  --gd:#163621;--gm:#2a5c42;--gl:#3d7f5f;--gb:#52a87a;--ac:#74c69d;
  --t1:#e8ede5;--t2:#a8c2ae;--t3:#7a9e8a;
  --bdr:#172e1f;--bdr2:#223d2e;
  --r:9px;--rl:14px;
  --cs-col:#52a87a;--cl-col:#fb923c;--uw-col:#93c5fd;
}
html{scroll-behavior:smooth}
body{font-family:'Noto Sans TC','微軟正黑體','Microsoft JhengHei',sans-serif;background:var(--bg);color:var(--t1);font-size:18px;line-height:1.8}
h1{font-size:2.8rem;font-weight:700;line-height:1.18;letter-spacing:-.02em}
h2{font-size:1.9rem;font-weight:700;margin-bottom:1.1rem;letter-spacing:-.01em}
h3{font-size:1.32rem;font-weight:600;margin-bottom:.72rem}
h4{font-size:1.08rem;font-weight:600;margin-bottom:.5rem}
p{margin-bottom:1rem}
strong{color:var(--ac)}
a{color:var(--gb)}

/* ── NAV ── */
#nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(9,24,15,.97);backdrop-filter:blur(14px);border-bottom:1px solid var(--bdr);display:flex;align-items:center;height:62px;padding:0 1.8rem}
.nav-brand{font-size:.95rem;font-weight:700;color:var(--ac);white-space:nowrap;margin-right:1.5rem;flex-shrink:0}
.nav-links{display:flex;overflow-x:auto;scrollbar-width:none}
.nav-links::-webkit-scrollbar{display:none}
#nav a{color:var(--t2);font-size:.84rem;padding:0 .9rem;height:62px;display:flex;align-items:center;white-space:nowrap;border-bottom:3px solid transparent;transition:.2s all}
#nav a:hover,#nav a.on{color:var(--ac);border-bottom-color:var(--ac)}

/* ── LAYOUT ── */
.wrap{max-width:1180px;margin:0 auto;padding:0 2.2rem}
section{padding:5.5rem 0 4.5rem;border-bottom:1px solid var(--bdr)}
.sec-no{font-size:.8rem;font-weight:700;color:var(--gb);text-transform:uppercase;letter-spacing:.14em;margin-bottom:.45rem}
.sec-hd{margin-bottom:2.5rem}

/* ── HERO ── */
#hero{padding-top:7.5rem;padding-bottom:4.5rem;position:relative;overflow:hidden;border-bottom:1px solid var(--bdr)}
.hero-bg{position:absolute;inset:0;opacity:.18;background-image:radial-gradient(circle,var(--gm) 1px,transparent 1px);background-size:28px 28px;animation:bgPan 40s linear infinite}
@keyframes bgPan{0%{background-position:0 0}100%{background-position:56px 56px}}
.hero-inner{position:relative;z-index:1}
.hero-badge{display:inline-flex;align-items:center;gap:.6rem;background:var(--gd);border:1px solid var(--gm);color:var(--ac);font-size:.84rem;font-weight:700;padding:.4rem 1.15rem;border-radius:2rem;margin-bottom:1.5rem;letter-spacing:.07em}
.hero-badge::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--ac);animation:blink 1.5s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.hero-sub{color:var(--t2);font-size:1.08rem;margin-top:.9rem}
.hero-note{color:var(--t3);font-size:.92rem;margin-top:1.05rem}
.hero-conclusion{background:var(--bgc);border:1px solid var(--bdr2);border-left:4px solid var(--gm);border-radius:var(--r);padding:1.5rem 1.8rem;margin-top:1.7rem;font-size:1.02rem;color:var(--t2);line-height:1.78}
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem;margin-top:2.2rem}
.stat-card{background:var(--bgc);border:1px solid var(--bdr);border-radius:var(--r);padding:1.4rem 1.2rem;text-align:center;transition:border-color .25s,transform .25s,box-shadow .25s}
.stat-card:hover{border-color:var(--gm);transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.3)}
.stat-val{font-size:2.2rem;font-weight:700;color:var(--ac);font-variant-numeric:tabular-nums}
.stat-label{font-size:.84rem;color:var(--t3);margin-top:.28rem;line-height:1.45}
.stat-ev{font-size:.72rem;font-weight:700;padding:.13rem .55rem;border-radius:3px;margin-top:.45rem;display:inline-block}
.ev-a{background:#0f3460;color:#60a5fa}.ev-b{background:#0a2818;color:#4ade80}
.ev-c{background:#2a2400;color:#facc15}.ev-d{background:#2d1800;color:#fb923c}

/* ── TAGS ── */
.tag{display:inline-block;font-size:.74rem;font-weight:700;padding:.16rem .58rem;border-radius:3px;vertical-align:middle;margin-left:.4rem;letter-spacing:.03em}
.ta{background:#0f3460;color:#60a5fa}.tb{background:#0a2818;color:#4ade80}
.tc{background:#2a2400;color:#facc15}.td{background:#2d1800;color:#fb923c}
.t-ver{background:#0f3460;color:#60a5fa}.t-ven{background:#3d1800;color:#fb923c}
.t-inf{background:#2a1040;color:#c084fc}.t-unk{background:#1a2a1a;color:#86efac}
.t-nv{background:#3d0f0f;color:#f87171}

/* ── CARDS / GRID ── */
.card{background:var(--bgc);border:1px solid var(--bdr);border-radius:var(--rl);padding:1.8rem;margin-bottom:1.1rem;transition:border-color .25s,box-shadow .25s}
.card:hover{border-color:var(--bdr2);box-shadow:0 4px 16px rgba(0,0,0,.2)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin-bottom:1.1rem}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;margin-bottom:1.1rem}
.ga{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.2rem;margin-bottom:1.1rem}

/* ── TABLE ── */
.tw{overflow-x:auto;margin:1.4rem 0;border-radius:var(--r);border:1px solid var(--bdr)}
table{width:100%;border-collapse:collapse;font-size:.96rem}
th{background:var(--gd);color:var(--ac);padding:.8rem 1.05rem;text-align:left;font-weight:600;white-space:nowrap;font-size:.96rem}
td{padding:.75rem 1.05rem;border-top:1px solid var(--bdr);vertical-align:top}
tr:hover td{background:rgba(255,255,255,.025)}

/* ── TABS ── */
.tabs{display:flex;border-bottom:1px solid var(--bdr);margin-bottom:1.7rem}
.tab-btn{background:none;border:none;border-bottom:3px solid transparent;color:var(--t2);font-size:.97rem;font-weight:500;padding:.8rem 1.4rem;cursor:pointer;transition:.2s;font-family:inherit}
.tab-btn:hover{color:var(--t1)}.tab-btn.on{color:var(--ac);border-bottom-color:var(--ac)}
.pane{display:none}.pane.on{display:block}

/* ── EVIDENCE ACCORDION ── */
.ev-item{border:1px solid var(--bdr);border-radius:var(--r);margin-bottom:.75rem;overflow:hidden;transition:border-color .2s}
.ev-item:hover{border-color:var(--bdr2)}
.ev-hdr{display:flex;align-items:center;gap:1rem;padding:1.05rem 1.35rem;cursor:pointer;background:var(--bgc);user-select:none;transition:.2s}
.ev-hdr:hover{background:var(--bgc2)}
.ev-lv{width:40px;height:40px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.08rem;flex-shrink:0}
.ev-hdr-title{flex:1;font-size:1rem;font-weight:600}
.ev-hdr-count{font-size:.86rem;color:var(--t3)}
.ev-chevron{color:var(--t3);font-size:.9rem;transition:transform .3s}
.ev-body{max-height:0;overflow:hidden;transition:max-height .55s ease}
.ev-body.open{max-height:2400px}
.ev-body-inner{padding:1.05rem 1.35rem;font-size:.92rem;color:var(--t2);line-height:1.72;border-top:1px solid var(--bdr)}

/* ── RADAR CHART ── */
.radar-wrap{display:flex;align-items:center;gap:2.5rem;flex-wrap:wrap}
.radar-svg-wrap{flex-shrink:0}
.radar-legend{display:flex;flex-direction:column;gap:.9rem}
.rl-item{display:flex;align-items:center;gap:.7rem;font-size:.92rem}
.rl-dot{width:14px;height:14px;border-radius:3px;flex-shrink:0}

/* ── ARCH DIAGRAM (animated SVG) ── */
.arch-svg-wrap{overflow-x:auto;background:var(--bgc);border:1px solid var(--bdr);border-radius:var(--rl);padding:1.8rem}
.arch-svg-wrap svg text{font-family:'Noto Sans TC','微軟正黑體',sans-serif}

/* ── KPI GAUGES ── */
.gauge-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:1.2rem;margin-bottom:1.2rem}
.gauge-card{background:var(--bgc);border:1px solid var(--bdr);border-radius:var(--r);padding:1.2rem;text-align:center;transition:border-color .25s,transform .2s}
.gauge-card:hover{border-color:var(--gm);transform:translateY(-2px)}
.gauge-note{font-size:.82rem;color:var(--t3);margin-top:.4rem;line-height:1.45}

/* ── TIMELINE ── */
.tl{position:relative;padding-left:2.2rem}
.tl::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--gm),var(--gd))}
.tl-item{position:relative;margin-bottom:2.1rem;padding-left:1.6rem}
.tl-item::before{content:'';position:absolute;left:-2.55rem;top:.38rem;width:13px;height:13px;border-radius:50%;background:var(--gm);border:2px solid var(--ac)}
.tl-period{font-size:.82rem;font-weight:700;color:var(--ac);text-transform:uppercase;letter-spacing:.09em;margin-bottom:.38rem}

/* ── CONSTRAINT CARDS ── */
.con-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.2rem}
.con{background:var(--bgc);border:1px solid var(--bdr);border-left:4px solid var(--gm);border-radius:var(--r);padding:1.3rem 1.5rem;transition:transform .2s,box-shadow .2s}
.con:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(0,0,0,.25)}
.con.warn{border-left-color:#d97706}.con.caution{border-left-color:#7c3aed}
.con-lbl{font-size:.76rem;font-weight:700;text-transform:uppercase;letter-spacing:.11em;color:var(--t3);margin-bottom:.42rem}
.con-title{font-size:1rem;font-weight:600;margin-bottom:.52rem}
.con-body{font-size:.9rem;color:var(--t2);line-height:1.68}

/* ── COMPLIANCE STRIPE (animated) ── */
.compliance-bg{
  background:repeating-linear-gradient(45deg,transparent,transparent 10px,rgba(217,119,6,.04) 10px,rgba(217,119,6,.04) 20px);
  animation:stripe 3s linear infinite;border-left:4px solid #d97706;
}
@keyframes stripe{0%{background-position:0 0}100%{background-position:28px 28px}}

/* ── DEMO: UW RISK ENGINE ── */
.demo-wrap{display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start}
.demo-panel{background:var(--bgc);border:1px solid var(--bdr);border-radius:var(--rl);padding:1.8rem}
.fg{margin-bottom:1.2rem}
.fg label{display:block;font-size:.9rem;font-weight:600;color:var(--t2);margin-bottom:.4rem}
.fg input,.fg select{width:100%;background:var(--bg);border:1px solid var(--bdr2);border-radius:var(--r);color:var(--t1);font-size:.97rem;padding:.62rem .95rem;font-family:inherit;transition:.2s}
.fg input:focus,.fg select:focus{outline:none;border-color:var(--gm);box-shadow:0 0 0 2px rgba(42,92,66,.3)}
.fg .hint{font-size:.8rem;color:var(--t3);margin-top:.28rem}
.rrow{display:flex;align-items:center;gap:.65rem}
.rrow input[type=range]{flex:1;accent-color:var(--gb);height:6px;padding:0}
.rval{font-size:.97rem;font-weight:700;color:var(--ac);min-width:3.5rem;text-align:right}
.run-btn{width:100%;background:var(--gm);border:none;border-radius:var(--r);color:#fff;font-size:1rem;font-weight:700;padding:.92rem;cursor:pointer;font-family:inherit;transition:.2s;margin-top:.55rem;letter-spacing:.04em}
.run-btn:hover{background:var(--gl);transform:translateY(-1px);box-shadow:0 4px 12px rgba(42,92,66,.5)}
.run-btn:active{transform:scale(.98)}

/* UW rules viz */
.rule-list{list-style:none;padding:0;margin-bottom:1.2rem}
.rule-item{display:flex;align-items:center;gap:.85rem;padding:.75rem 1rem;border-radius:var(--r);margin-bottom:.55rem;font-size:.9rem;border:1px solid var(--bdr);transition:.4s all}
.rule-item.pass{border-color:#2d6a4f;background:rgba(45,106,79,.12)}
.rule-item.refer{border-color:#1e3a8a;background:rgba(30,58,138,.12)}
.rule-item.warn{border-color:#92400e;background:rgba(146,64,14,.10)}
.rule-dot{width:11px;height:11px;border-radius:50%;flex-shrink:0;background:var(--t3)}
.rule-item.pass .rule-dot{background:#4ade80}
.rule-item.refer .rule-dot{background:#93c5fd}
.rule-item.warn .rule-dot{background:#fb923c}
.rule-label{flex:1}
.rule-result{font-size:.82rem;font-weight:700;color:var(--t3)}
.rule-item.pass .rule-result{color:#4ade80}
.rule-item.refer .rule-result{color:#93c5fd}
.rule-item.warn .rule-result{color:#fb923c}

/* Decision badge */
.decision-badge{display:inline-flex;align-items:center;gap:.6rem;font-size:1.02rem;font-weight:700;padding:.62rem 1.25rem;border-radius:2rem;margin-bottom:.95rem}
.dec-pass{background:rgba(74,222,128,.15);border:1px solid #4ade80;color:#4ade80}
.dec-warn{background:rgba(251,146,60,.15);border:1px solid #fb923c;color:#fb923c}
.dec-ref{background:rgba(147,197,253,.15);border:1px solid #93c5fd;color:#93c5fd}

/* ── DEMO: FRAUD SCORE ── */
.factor-bars{display:flex;flex-direction:column;gap:.9rem;margin:1.3rem 0}
.factor-row{display:flex;align-items:center;gap:.85rem;font-size:.88rem}
.factor-name{width:9rem;color:var(--t2);flex-shrink:0;text-align:right}
.factor-bar-wrap{flex:1;background:var(--bdr);border-radius:4px;height:12px;overflow:hidden;position:relative}
.factor-bar{height:100%;border-radius:4px;transition:width .8s ease;background:linear-gradient(90deg,var(--gm),var(--gb))}
.factor-bar.hi{background:linear-gradient(90deg,#d97706,#fb923c)}
.factor-val{width:3.5rem;text-align:right;font-weight:600;color:var(--ac);flex-shrink:0}
.score-gauge-wrap{display:flex;flex-direction:column;align-items:center;margin:1.3rem 0}
.score-num{font-size:3.4rem;font-weight:700;font-variant-numeric:tabular-nums;transition:color .4s}
.score-label{font-size:.9rem;color:var(--t3);margin-top:.15rem}
.score-bar-wrap{width:100%;background:var(--bdr);border-radius:5px;height:16px;overflow:hidden;position:relative;margin:.95rem 0}
.score-bar{height:100%;border-radius:5px;transition:width .8s ease,background .4s}
.score-thresholds{display:flex;justify-content:space-between;font-size:.78rem;color:var(--t3);margin-top:.28rem;padding:0 2px}

/* ── ROI CALCULATOR ── */
.roi-wrap{display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start}
.out-metric{margin-bottom:1.2rem;padding-bottom:1.2rem;border-bottom:1px solid var(--bdr)}
.out-metric:last-child{border-bottom:none;margin-bottom:0}
.out-lbl{font-size:.86rem;color:var(--t3);margin-bottom:.28rem}
.out-val{font-size:1.85rem;font-weight:700;color:var(--ac)}
.out-unit{font-size:.9rem;color:var(--t2);margin-left:.28rem}
.warn-list{list-style:none;padding:0}
.warn-list li{font-size:.9rem;color:#fb923c;padding:.3rem 0 .3rem 1.3rem;position:relative}
.warn-list li::before{content:'⚠';position:absolute;left:0}
.pri-box{background:var(--bg);border:1px solid var(--gm);border-radius:var(--r);padding:.95rem 1.15rem;font-size:.92rem;color:var(--ac);line-height:1.62}

/* ── CHECKLIST ── */
.chk{list-style:none;padding:0}
.chk li{padding:.95rem 1.15rem;border-bottom:1px solid var(--bdr);display:flex;gap:1.05rem;align-items:flex-start}
.chk li:last-child{border-bottom:none}
.chk-ico{width:23px;height:23px;border-radius:50%;background:var(--gd);border:1px solid var(--gm);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.74rem;color:var(--ac);margin-top:.2rem}
.chk-title{font-size:.97rem;font-weight:600;margin-bottom:.22rem}
.chk-detail{font-size:.86rem;color:var(--t2)}

/* ── KP LIST ── */
.kp{list-style:none;padding:0}
.kp li{padding:.68rem 0;border-bottom:1px solid var(--bdr);padding-left:1.55rem;position:relative;font-size:.97rem}
.kp li::before{content:'▸';position:absolute;left:0;color:var(--ac)}

/* ── PRIORITY ── */
.pri{display:inline-block;font-size:.8rem;font-weight:700;padding:.2rem .72rem;border-radius:2rem;letter-spacing:.04em}
.pri-hi{background:#0f3020;color:#4ade80;border:1px solid #2d6a4f}
.pri-md{background:#1a2600;color:#bef264;border:1px solid #4d7c0f}
.pri-st{background:#0f1840;color:#93c5fd;border:1px solid #1e3a8a}

/* ── SOURCE LIST ── */
.src{list-style:none;padding:0}
.src li{padding:.7rem 0;border-bottom:1px solid var(--bdr);font-size:.9rem;display:flex;align-items:flex-start;gap:.7rem}
.src-lv{width:21px;height:21px;border-radius:3px;text-align:center;line-height:21px;font-size:.72rem;font-weight:700;flex-shrink:0}

/* ── SCROLL REVEAL ── */
.rv{opacity:0;transform:translateY(24px);transition:opacity .65s,transform .65s}
.rv.vis{opacity:1;transform:translateY(0)}
.rv2{opacity:0;transform:translateY(24px);transition:opacity .65s .18s,transform .65s .18s}
.rv2.vis{opacity:1;transform:translateY(0)}
.rv3{opacity:0;transform:translateY(24px);transition:opacity .65s .36s,transform .65s .36s}
.rv3.vis{opacity:1;transform:translateY(0)}

/* ── DEMO disclaimer ── */
.demo-disclaimer{font-size:.82rem;color:var(--t3);line-height:1.58;margin-top:1rem;padding:.82rem 1.05rem;background:var(--bg);border-radius:var(--r);border:1px solid var(--bdr)}

/* ── KPI CARDS ── */
.kpi-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(205px,1fr));gap:1.2rem}
.kpi-c{background:var(--bgc);border:1px solid var(--bdr);border-radius:var(--r);padding:1.25rem;transition:border-color .25s,transform .2s}
.kpi-c:hover{border-color:var(--gm);transform:translateY(-2px)}
.kpi-n{font-size:.9rem;font-weight:700;color:var(--ac);margin-bottom:.24rem}
.kpi-f{font-size:.8rem;color:var(--t3);margin-bottom:.42rem}
.kpi-formula{font-size:.8rem;font-family:monospace;background:var(--bg);padding:.38rem .62rem;border-radius:5px;color:var(--t2);margin-bottom:.42rem}
.kpi-tags{display:flex;gap:.3rem;flex-wrap:wrap}
.kpi-st{font-size:.72rem;padding:.13rem .48rem;border-radius:3px;background:var(--gd);color:var(--ac)}

/* ── RESP ── */
@media(max-width:768px){
  h1{font-size:1.75rem}h2{font-size:1.4rem}h3{font-size:1.1rem}
  .g2,.g3,.demo-wrap,.roi-wrap{grid-template-columns:1fr}
  .stats-row{grid-template-columns:repeat(2,1fr)}
  .nav-brand{display:none}
  section{padding:3.5rem 0 3rem}
  body{font-size:16px}
  .tabs{flex-wrap:wrap}
  .tab-btn{font-size:.88rem;padding:.68rem 1rem}
  .wrap{padding:0 1.4rem}
}
footer{padding:2.2rem;text-align:center;font-size:.84rem;color:var(--t3);border-top:1px solid var(--bdr)}
footer a{color:var(--t3);border-bottom:1px solid transparent;transition:color .2s,border-color .2s}
footer a:hover{color:var(--ac);border-bottom-color:rgba(116,198,157,.4)}

/* ══ SCROLL PROGRESS ══ */
#pgbar{position:fixed;top:0;left:0;height:3px;width:0%;z-index:600;pointer-events:none;
  background:linear-gradient(90deg,var(--gm) 0%,var(--ac) 55%,var(--gb) 100%);
  transition:width .08s linear;border-radius:0 2px 2px 0}

/* ══ BACK TO TOP ══ */
#top-btn{position:fixed;bottom:2.2rem;right:2rem;width:46px;height:46px;
  background:var(--gd);border:1px solid var(--gm);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  color:var(--ac);font-size:1.25rem;font-weight:700;cursor:pointer;
  opacity:0;transform:translateY(10px) scale(.9);
  transition:opacity .3s,transform .3s,background .2s,box-shadow .2s;
  z-index:150;box-shadow:0 4px 18px rgba(0,0,0,.4);
  text-decoration:none;line-height:1;user-select:none;border-bottom:none!important}
#top-btn.show{opacity:1;transform:translateY(0) scale(1)}
#top-btn:hover{background:var(--gm);box-shadow:0 6px 22px rgba(42,92,66,.5);transform:translateY(-2px) scale(1.05)}

/* ══ LINKS (in content areas only) ══ */
.card a,.ev-body-inner a,.src li a,.con-body a,.hero-conclusion a,.bq a,.find a,.case-sub a,.case-benefits a,.dim-body a{
  color:var(--gb);border-bottom:1px solid rgba(82,168,122,.35);
  text-decoration:none;transition:color .2s,border-color .2s}
