document.querySelectorAll('.demo-panel').forEach(p=>{
  p.addEventListener('focusin',()=>p.classList.add('lit'));
  p.addEventListener('focusout',e=>{
    if(!p.contains(e.relatedTarget)) p.classList.remove('lit');
  });
});
