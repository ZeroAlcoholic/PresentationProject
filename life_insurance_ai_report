// ── KPI GAUGES ──
function drawGauge(id,pct,label,col){
  const svg=document.getElementById(id);if(!svg)return;
  const NS='http://www.w3.org/2000/svg';
  const cx=80,cy=80,R=55,sw=10;
  function arc(cx,cy,r,startA,endA){
    const s=[cx+r*Math.cos(startA),cy+r*Math.sin(startA)];
    const e=[cx+r*Math.cos(endA),cy+r*Math.sin(endA)];
    const lg=endA-startA>Math.PI?1:0;
    return `M${s[0]},${s[1]} A${r},${r} 0 ${lg} 1 ${e[0]},${e[1]}`;
  }
  const sa=Math.PI,ea=2*Math.PI;
  const bg=document.createElementNS(NS,'path');
  bg.setAttribute('d',arc(cx,cy,R,sa,ea));
  bg.setAttribute('fill','none');bg.setAttribute('stroke','#172e1f');bg.setAttribute('stroke-width',sw);
  bg.setAttribute('stroke-linecap','round');svg.appendChild(bg);
  const va=document.createElementNS(NS,'path');
  va.setAttribute('d',arc(cx,cy,R,sa,sa+pct*Math.PI));
  va.setAttribute('fill','none');va.setAttribute('stroke',col||'#52b788');va.setAttribute('stroke-width',sw);
  va.setAttribute('stroke-linecap','round');
  svg.appendChild(va);
  const vt=document.createElementNS(NS,'text');
  vt.setAttribute('x',cx);vt.setAttribute('y',cy-6);
  vt.setAttribute('text-anchor','middle');vt.setAttribute('fill',col||'#74c69d');
  vt.setAttribute('font-size','18');vt.setAttribute('font-weight','700');
  vt.textContent=Math.round(pct*100)+'%';svg.appendChild(vt);
  const lt=document.createElementNS(NS,'text');
  lt.setAttribute('x',cx);lt.setAttribute('y',cy+14);
  lt.setAttribute('text-anchor','middle');lt.setAttribute('fill','#7a9e8a');
  lt.setAttribute('font-size','9');lt.textContent=label;svg.appendChild(lt);
}
