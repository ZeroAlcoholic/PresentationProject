// ── DEMO 1: UNDERWRITING RULE ENGINE ──
// Rules are illustrative (示意性規則，非實際核保書). Source: report architecture principle.
function runUW(){
  const age=parseInt(document.getElementById('uw-age').value);
  const bmi=parseFloat(document.getElementById('uw-bmi').value);
  const smoke=parseInt(document.getElementById('uw-smoke').value);
  const occ=parseInt(document.getElementById('uw-occ').value);
  const amt=parseInt(document.getElementById('uw-amt').value);

  // === LAYER 1: Rules Engine ===
  // Each rule produces: {id, name, status:'pass'|'warn'|'fail', detail, requiresHITL}
  const rules=[];

  // R01 Age
  if(age<=45) rules.push({id:'R01',name:'年齡限制',status:'pass',detail:`年齡 ${age} 歲，在標準承保範圍（≤45）內`,requiresHITL:false});
  else if(age<=60) rules.push({id:'R01',name:'年齡限制',status:'warn',detail:`年齡 ${age} 歲，建議核保師確認（46–60 加費區間）`,requiresHITL:false});
  else rules.push({id:'R01',name:'年齡限制',status:'refer',detail:`年齡 ${age} 歲，61 歲以上須人工核保`,requiresHITL:true});

  // R02 BMI
  if(bmi<28) rules.push({id:'R02',name:'BMI 指標',status:'pass',detail:`BMI ${bmi.toFixed(1)}，在標準範圍（<28）`,requiresHITL:false});
  else if(bmi<=35) rules.push({id:'R02',name:'BMI 指標',status:'warn',detail:`BMI ${bmi.toFixed(1)}，屬加費區間（28–35），建議附加醫療問卷`,requiresHITL:false});
  else rules.push({id:'R02',name:'BMI 指標',status:'refer',detail:`BMI ${bmi.toFixed(1)} > 35，高風險，須人工核保師評估`,requiresHITL:true});

  // R03 Smoking
  if(!smoke) rules.push({id:'R03',name:'吸菸狀態',status:'pass',detail:'非吸菸者，標準費率',requiresHITL:false});
  else rules.push({id:'R03',name:'吸菸狀態',status:'warn',detail:'吸菸者，適用吸菸加費（次標準），需核保師確認',requiresHITL:false});

  // R04 Occupation
  const occNames=['','Class 1 — 辦公室（標準）','Class 2 — 輕度體力（標準）','Class 3 — 重度體力（加費）','Class 4 — 高危險職業'];
  if(occ<=2) rules.push({id:'R04',name:'職業風險',status:'pass',detail:`${occNames[occ]}，標準核保範圍`,requiresHITL:false});
  else if(occ===3) rules.push({id:'R04',name:'職業風險',status:'warn',detail:'重度體力勞動，需加費並附職業問卷',requiresHITL:false});
  else rules.push({id:'R04',name:'職業風險',status:'refer',detail:'高危險職業，須人工核保師逐案評估',requiresHITL:true});

  // R05 Sum assured threshold
  if(amt<=1000) rules.push({id:'R05',name:'保額閾值',status:'pass',detail:`申請保額 ${amt} 萬，在標準閾值（≤1,000 萬）內`,requiresHITL:false});
  else if(amt<=3000) rules.push({id:'R05',name:'保額閾值',status:'warn',detail:`申請保額 ${amt} 萬，中高保額，需財務核保審查`,requiresHITL:false});
  else rules.push({id:'R05',name:'保額閾值',status:'refer',detail:`申請保額 ${amt} 萬，超過 3,000 萬，須資深核保師人工評估`,requiresHITL:true});

  // === Composite Decision ===
  const needsHITL=rules.some(r=>r.requiresHITL);
  const warnCount=rules.filter(r=>r.status==='warn').length;
  let decision,decClass,summary;
  if(needsHITL){
    decision='🔴 須人工核保 (Human Underwriting Required)';
    decClass='dec-ref';
    summary='一或多項規則觸發人工審查閾值。依報告原則：任何觸發強制轉介規則的案件均需核保師逐案評估，系統不做自動拒保。 <span class="tag t-ver">architecture verified — A/B level sources</span>';
  } else if(warnCount>=2){
    decision='🟡 次標準 — 建議人工核保確認 (Rated — Human Confirmation Recommended)';
    decClass='dec-warn';
    summary=`偵測到 ${warnCount} 項注意指標，無強制人工要求但建議核保師確認加費條件與比率。 <span class="tag t-inf">inferred from report architecture</span>`;
  } else if(warnCount===1){
    decision='🟡 次標準 — 可能加費 (Possible Rate Loading)';
    decClass='dec-warn';
    summary='一項風險因子觸發，建議核保師確認是否適用標準加費條件。';
  } else {
    decision='🟢 標準費率 (Standard — Eligible for Accelerated UW)';
    decClass='dec-pass';
    summary='所有規則通過，此案件可進入加速核保流程（Accelerated Underwriting）。如無其他問題，可由系統自動核准。 <span class="tag t-inf">inferred — MassMutual, RGA 案例架構</span>';
  }

  // Render
  document.getElementById('uw-decision').innerHTML=`<div class="decision-badge ${decClass}">${decision}</div>`;
  const ul=document.getElementById('uw-rules');ul.innerHTML='';
  rules.forEach(r=>{
    const li=document.createElement('li');
    li.className=`rule-item ${r.status}`;
    li.innerHTML=`<div class="rule-dot"></div><div class="rule-label"><strong>${r.id}</strong> ${r.name}<div style="font-size:.82rem;color:var(--t3);margin-top:.18rem">${r.detail}</div></div><div class="rule-result">${r.status==='pass'?'通過':r.status==='refer'?'轉介人工':r.status==='warn'?'注意':'確認'}</div>`;
    ul.appendChild(li);
  });
  document.getElementById('uw-summary').innerHTML=summary;
  const out=document.getElementById('uw-output');
  out.style.opacity='1';
  out.classList.add('lit');
  out.scrollIntoView({behavior:'smooth',block:'nearest'});
}

// ── DEMO 2: FRAUD SCORE DECOMPOSITION ──
// Weights and thresholds are illustrative. Source: report architecture (Shift, FRISS, MetLife+Sprout.ai).
function runFraud(){
  const claimType=document.getElementById('fr-type').value;
  const amt=parseInt(document.getElementById('fr-amt').value);
  const policyMonths=parseInt(document.getElementById('fr-age').value);
  const cnt=parseInt(document.getElementById('fr-cnt').value);
  const hospTier=parseInt(document.getElementById('fr-hosp').value);

  // Type averages (illustrative)
  const avgAmt={medical:30000,surgical:80000,critical:200000,accident:50000};
  const avgA=avgAmt[claimType]||50000;

  // === Factor Scoring (0–1 per factor) ===
  // F1: Amount ratio vs. type average (weight 30%)
  const amtRatio=amt/avgA;
  const f1=Math.min(Math.max((amtRatio-0.5)/2.5,0),1);

  // F2: Policy age — new policy risk (weight 25%)
  // 1 month=1.0, 12 months=0.5, 24+months=0
  const f2=Math.max(1-(policyMonths/24),0);

  // F3: Hospital tier (weight 20%)
  // 1=醫學中心(0), 2=區域(0.2), 3=地區(0.5), 4=診所(1.0)
  const f3Map={1:0,2:0.2,3:0.5,4:1.0};
  const f3=f3Map[hospTier]||0.3;

  // F4: Recent claims frequency (weight 25%)
  const f4=Math.min(cnt/6,1);

  const weights=[.30,.25,.20,.25];
  const scores=[f1,f2,f3,f4];
  const fraudRaw=scores.reduce((s,v,i)=>s+v*weights[i],0);
  const fraudScore=Math.round(fraudRaw*100);

  // Threshold-based routing
  let routeDecision,routeClass,routeReason;
  if(fraudScore<=30){
    routeDecision='🟢 快速核准通道 (Fast-Track Auto-Approve)';
    routeClass='dec-pass';
    routeReason='綜合風險評分低，符合自動核准條件。可進入 STP 快通流程，縮短 TAT。正常客戶可更快取得理賠。';
  } else if(fraudScore<=60){
    routeDecision='🟡 人工覆核佇列 (Human Review Queue)';
    routeClass='dec-warn';
    routeReason='綜合風險評分中等，案件送理賠處理員人工覆核。處理員可查看因子分解細節，優先審閱高權重因子觸發原因。';
  } else {
    routeDecision='🔴 SIU 調查優先 (SIU Investigation Priority)';
    routeClass='dec-ref';
    routeReason='綜合風險評分高，案件升級至 SIU（特別調查單位）優先排程。本決策仍由調查員確認，不做自動拒賠。';
  }

  // Render score
  const scoreEl=document.getElementById('fr-score');
  scoreEl.textContent=fraudScore;
  scoreEl.style.color=fraudScore<=30?'#4ade80':fraudScore<=60?'#fb923c':'#f87171';
  const barEl=document.getElementById('fr-bar');
  barEl.style.width=fraudScore+'%';
  barEl.style.background=fraudScore<=30?'linear-gradient(90deg,#2d6a4f,#4ade80)':fraudScore<=60?'linear-gradient(90deg,#b45309,#fb923c)':'linear-gradient(90deg,#7f1d1d,#f87171)';

  // Factors
  const factorNames=['F1 申請金額比（相對類型平均）','F2 投保年資（新契約風險）','F3 就醫院所層級','F4 近期理賠頻率'];
  const factorDetails=[
    `申請 NT$${amt.toLocaleString()} vs 類型平均 NT$${avgA.toLocaleString()}（比率 ${amtRatio.toFixed(2)}）`,
    `投保 ${policyMonths} 個月（< 12 月高風險）`,
    ['醫學中心（低風險）','區域醫院','地區醫院','診所（較高風險）'][hospTier-1],
    `近 3 年 ${cnt} 次理賠`
  ];
  const factsEl=document.getElementById('fr-factors');factsEl.innerHTML='';
  scores.forEach((s,i)=>{
    const contrib=Math.round(s*weights[i]*100);
    const isHi=contrib>=15;
    factsEl.innerHTML+=`
      <div class="factor-row">
        <div class="factor-name">${factorNames[i].split('（')[0]}</div>
        <div class="factor-bar-wrap"><div class="factor-bar ${isHi?'hi':''}" style="width:${s*100}%"></div></div>
        <div class="factor-val">+${contrib}pt</div>
      </div>
      <div style="font-size:.7rem;color:var(--t3);margin:-4px 0 4px 8.5rem;padding-bottom:4px;border-bottom:1px solid var(--bdr)">${factorDetails[i]}  ·  權重 ${Math.round(weights[i]*100)}%</div>`;
  });
  document.getElementById('fr-decision').innerHTML=`<div class="decision-badge ${routeClass}">${routeDecision}</div>`;
  document.getElementById('fr-reason').textContent=routeReason;
  const frOut=document.getElementById('fr-output');
  frOut.style.opacity='1';
  frOut.classList.add('lit');
  frOut.scrollIntoView({behavior:'smooth',block:'nearest'});
}

// ── DEMO 3: ROI CALCULATOR ──
function calcROI(){
  const scene=document.getElementById('roi-scene').value;
  const vol=parseFloat(document.getElementById('roi-vol').value)||0;
  const autoRate=parseFloat(document.getElementById('roi-auto').value)/100;
  const ovrRate=parseFloat(document.getElementById('roi-ovr').value)/100;
  const mins=parseFloat(document.getElementById('roi-min').value)||1;
  const costPerHr=parseFloat(document.getElementById('roi-cost').value)||0;

  const netAuto=vol*autoRate*(1-ovrRate);
  const hoursSaved=netAuto*mins/60;
  const costSaved=hoursSaved*costPerHr;

  document.getElementById('roi-hours').textContent=Math.round(hoursSaved).toLocaleString();
  document.getElementById('roi-cost-out').textContent=Math.round(costSaved).toLocaleString();

  const warns=[];
  if(ovrRate>0.30) warns.push('人工推翻率超過 30%，建議重新檢視模型閾值或訓練資料品質');
  if(autoRate>0.70) warns.push('自動化率設定偏高（>70%），初期建議保守設定');
  if(autoRate<0.10) warns.push('自動化率低於 10%，效益有限，建議先確認流程設計');
  if(vol<1000) warns.push('月案件量較低，固定導入成本可能影響整體 ROI 時程');
  const wEl=document.getElementById('roi-warns');
  wEl.innerHTML=warns.length?warns.map(w=>`<li>${w}</li>`).join(''):'<li style="color:var(--ac)">無明顯風險預警（請確認參數設定合理）</li>';

  const priMap={
    cs:'建議優先推進此場景：對醫療個資依賴最低、工具最成熟、見效最快，適合作為組織 AI 能力的第一個練兵場。（報告建議：先做 Agent Assist + 摘要）',
    cl:'建議第二優先：具備可量化硬 ROI（詐欺阻卻、TAT 縮短、人工工時），且分流設計對監理治理友善。（報告建議：先做 triage + 防詐，不先做自動拒賠）',
    uw:'建議最後推進：戰略價值最高，但依賴完整 rulebook、資料授權、模型監控與核保團隊 buy-in，初期門檻最高。（報告建議：先從簡單商品、低保額件開始）'
  };
  document.getElementById('roi-pri').textContent=priMap[scene];
  const roiOut=document.getElementById('roi-output');
  roiOut.style.opacity='1';
  roiOut.classList.add('lit');
  roiOut.scrollIntoView({behavior:'smooth',block:'nearest'});
}

// ── AUTO INJECT data-tip FROM CLASS (for all tags without existing data-tip) ──
(()=>{
  const tipMap={
    't-ver':'✓ verified — 有 A 或 B 級官方文件直接支持',
    't-ven':'vendor-claimed — 供應商官方宣稱，缺乏獨立第三方審計',
    't-inf':'inferred — 由多個案例或邏輯推導，非直接引用',
    't-unk':'public data not disclosed — 方向性揭露，無具體數字',
    't-nv':'⚠ needs verification — 引用層級低，採購前需透過 POC 實測',
    'ta':'A 級 — 監管機關／法律／年報（最高可信度）',
    'tb':'B 級 — 官方產品文件（供應商宣稱，未獨立審計）',
    'tc':'C 級 — 合作夥伴案例（需搭配 A/B 級交叉驗證）',
    'td':'D 級 — 可靠媒體（最低層級，採購前需驗證）'
  };
  document.querySelectorAll('.tag').forEach(el=>{
    if(el.dataset.tip)return;
    for(const[cls,tip] of Object.entries(tipMap)){
      if(el.classList.contains(cls)){el.dataset.tip=tip;break;}
    }
  });
})();

// ── NAV SECTION COUNT ──
(()=>{
  const secs=document.querySelectorAll('section[id]');
  const total=secs.length;
  let cur=0;
  const obs=new IntersectionObserver(es=>{
    es.forEach(e=>{
      if(e.isIntersecting){
        const idx=Array.from(secs).indexOf(e.target);
        if(idx>=0) cur=idx+1;
      }
    });
  },{rootMargin:'-35% 0px -60% 0px'});
  secs.forEach(s=>obs.observe(s));
})();

